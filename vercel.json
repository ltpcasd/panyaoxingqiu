{
  "version": 2,
  "builds": [
    {
      "src": "frontend/panyaoxingqiu-miniapp/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/build/h5"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/vercel-api/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/panyaoxingqiu-miniapp/dist/build/h5/$1"
    }
  ],
  "env": {
    "DATABASE_URL": "@mysql-database-url"
  }
}
