stateDiagram-v2
    [*] --> 正常状态: 配对成功
    
    state "正常状态" as Normal {
        [*] --> 活跃状态
        活跃状态 --> 活跃状态: 日常使用
    }
    
    正常状态 --> 解绑申请: 一方发起解绑
    
    state "解绑流程" as UnbindFlow {
        [*] --> 身份验证
        
        身份验证 --> 解绑原因选择: 验证通过
        身份验证 --> 身份验证: 验证失败，重试
        身份验证 --> [*]: 取消解绑
        
        解绑原因选择 --> 数据处理方式选择: 选择原因
        解绑原因选择 --> [*]: 取消解绑
        
        数据处理方式选择 --> 冷静期: 确认处理方案
        数据处理方式选择 --> [*]: 取消解绑
        
        state "冷静期" as Cooldown {
            [*] --> 等待期
            等待期 --> 等待期: 倒计时48小时
            等待期 --> 冷静期结束: 时间到
            等待期 --> [*]: 撤销解绑申请
        }
        
        冷静期 --> 双方确认: 冷静期结束
        
        state "双方确认" as Confirm {
            [*] --> 等待对方确认
            等待对方确认 --> 解绑生效: 双方确认
            等待对方确认 --> 等待对方确认: 等待中
            等待对方确认 --> [*]: 一方撤销
        }
    }
    
    解绑申请 --> 紧急解绑: 安全问题/账号被盗
    
    state "紧急解绑" as Emergency {
        [*] --> 提交紧急申请
        提交紧急申请 --> 系统冻结: 立即冻结空间
        系统冻结 --> 客服审核: 24小时内审核
        客服审核 --> 解绑生效: 审核通过
        客服审核 --> 恢复正常: 审核不通过
        恢复正常 --> 活跃状态
    }
    
    双方确认 --> 解绑生效: 确认解绑
    紧急解绑 --> 解绑生效: 审核通过
    
    state "解绑生效" as Dissolved {
        [*] --> 数据归档
        数据归档 --> 个人数据保留: 保留个人数据
        数据归档 --> 共享数据锁定: 锁定30天
        共享数据锁定 --> 共享数据删除: 30天后删除
        个人数据保留 --> 单身状态
        共享数据删除 --> 单身状态
    }
    
    解绑生效 --> 单身状态: 解绑完成
    
    state "单身状态" as Single {
        [*] --> 可重新配对
        可重新配对 --> 可重新配对: 等待新配对
        可重新配对 --> [*]: 创建新关系
    }
    
    单身状态 --> 正常状态: 与新对象配对成功
    
    %% 异常流程
    正常状态 --> 异常状态: 检测到异常
    
    state "异常状态" as Abnormal {
        [*] --> 一方失联检测
        一方失联检测 --> 自动提醒: 7天未登录
        自动提醒 --> 自动提醒: 继续提醒
        自动提醒 --> 关系冻结: 30天未登录
        关系冻结 --> 自动解绑: 60天未登录
        自动提醒 --> 恢复正常: 重新登录
        关系冻结 --> 恢复正常: 重新登录
    }
    
    异常状态 --> 正常状态: 异常解除
    异常状态 --> 解绑生效: 自动解绑
    
    %% 状态说明
    note right of Normal
        双方正常使用情侣空间
        所有功能可用
    end note
    
    note right of Cooldown
        48小时冷静期
        防止冲动操作
        可随时撤销
    end note
    
    note right of Emergency
        针对安全问题
        立即冻结保护数据
        需客服人工审核
    end note
    
    note right of Dissolved
        解绑后的数据处理
        个人数据保留
        共享数据30天后删除
    end note

